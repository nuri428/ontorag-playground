# Graph store (fuseki | neo4j | falkordb)
GRAPH_STORE=fuseki
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=ontorag

# LLM (anthropic | openai | ollama)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local LLM via Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Anthropic
ANTHROPIC_API_KEY=

# Active domain directory (swap to change domain)
DOMAIN_DIR=domains/movie

# KMDB connector (Stage 3) — koreafilm.or.kr에서 발급
KMDB_SERVICE_KEY=

# Server
PORT=8200
LOG_LEVEL=info
